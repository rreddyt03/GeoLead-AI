SALESFORCE_AUTH_FLOW=password
SALESFORCE_CLIENT_ID=your_connected_app_consumer_key
SALESFORCE_CLIENT_SECRET=your_connected_app_consumer_secret
SALESFORCE_USERNAME=your_salesforce_username
SALESFORCE_PASSWORD=your_salesforce_password
SALESFORCE_SECURITY_TOKEN=your_salesforce_security_token
SALESFORCE_LOGIN_URL=https://login.salesforce.com
SALESFORCE_API_VERSION=v61.0

# If you use an External Client App with Client Credentials Flow instead,
# switch the auth flow and you can omit username/password/token.
# SALESFORCE_AUTH_FLOW=client_credentials

# Optional custom Salesforce Lead field API names
# Example: Window_Size__c
WINDOW_SIZE_FIELD=
WINDOW_TYPE_FIELD=
WINDOW_MATERIAL_FIELD=
WINDOW_TIMELINE_FIELD=
WINDOW_BUDGET_FIELD=
WINDOW_RECOMMENDED_MODEL_FIELD=
