# Core app
SECRET_KEY=replace_with_a_random_secret

# OpenAI
OPENAI_API_KEY=replace_with_your_openai_api_key
OPENAI_MODEL=gpt-4.1-mini

# Salesforce
SALESFORCE_AUTH_FLOW=client_credentials
SALESFORCE_CLIENT_ID=replace_with_salesforce_client_id
SALESFORCE_CLIENT_SECRET=replace_with_salesforce_client_secret
SALESFORCE_LOGIN_URL=https://your-instance.my.salesforce.com

# Optional Salesforce custom fields
SALESFORCE_AI_STATUS_FIELD=
WINDOW_SIZE_FIELD=
WINDOW_TYPE_FIELD=
WINDOW_MATERIAL_FIELD=
WINDOW_TIMELINE_FIELD=
WINDOW_BUDGET_FIELD=
WINDOW_RECOMMENDED_MODEL_FIELD=

# Optional email delivery
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SENDER=
SMTP_USE_TLS=true